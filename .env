# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────
# IMPORTANT: use a database dedicated to this project. Do NOT point this at a
# shared/company cluster. For local dev, run MongoDB locally or via Docker:
#   docker run -d -p 27017:27017 --name shayari-mongo mongo:7
MONGODB_URI=mongodb+srv://Avinash:Avinash@cluster0.uscfm.mongodb.net/

# ─── Client / CORS ────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── JWT secrets (generate strong random values in production) ─
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_RESET_SECRET=replace_me_reset
JWT_SECRET=twinsoul_super_secret_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=30m
JWT_VERIFY_EXPIRES_IN=1d

# ─── Cookies ──────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.yourdomain.com
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# ─── Security ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ─── Cloudinary (optional — falls back to local disk if unset) ─
